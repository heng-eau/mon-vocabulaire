<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="Mon Vocab"/>
<meta name="theme-color" content="#1a1a2e"/>
<title>Mon Vocabulaire</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{
  background:linear-gradient(165deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);
  color:#e0e0e0;
  font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","Microsoft YaHei",sans-serif;
  padding-top:env(safe-area-inset-top);
}
.app{height:100vh;display:flex;flex-direction:column;overflow:hidden}
.header{padding:16px 20px 10px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.logo{font-size:20px;font-weight:700;color:#e8c87a;letter-spacing:1px}
.sub{font-size:11px;color:#7a7a9a;margin-top:2px}
.tabs{display:flex;gap:6px}
.tab{padding:5px 14px;border-radius:20px;border:none;font-size:13px;font-weight:600;cursor:pointer}
.tab.on{background:#e8c87a;color:#1a1a2e}
.tab.off{background:rgba(255,255,255,.08);color:#888}
.content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px 20px 100px}
.card{background:rgba(255,255,255,.06);border-radius:20px;padding:36px 20px;text-align:center;margin-bottom:20px;border:1px solid rgba(232,200,122,.15);position:relative}
.counter{position:absolute;top:14px;right:18px;font-size:11px;color:#7a7a9a}
.word-fr{font-size:38px;font-weight:300;color:#fff;letter-spacing:2px;margin-bottom:14px;font-style:italic}
.word-zh{font-size:15px;color:#b0b0c8;margin-bottom:6px}
.word-ex{font-size:13px;color:#7a7a9a;font-style:italic;margin-top:10px}
.toggle-btn{margin-top:14px;background:none;border:1px solid rgba(255,255,255,.15);color:#7a7a9a;padding:4px 12px;border-radius:12px;font-size:11px;cursor:pointer}
.progress{height:3px;background:rgba(255,255,255,.08);border-radius:2px;margin-bottom:20px;overflow:hidden}
.progress-bar{height:100%;background:linear-gradient(90deg,#e8c87a,#d4a853);border-radius:2px;transition:width .3s ease}
.controls{display:flex;justify-content:center;align-items:center;gap:18px;margin-bottom:20px}
.ctrl-btn{border-radius:50%;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.05);color:#ccc;cursor:pointer;display:flex;align-items:center;justify-content:center}
.ctrl-sm{width:44px;height:44px;font-size:16px}
.ctrl-lg{width:60px;height:60px;font-size:22px;border:none;background:linear-gradient(135deg,#e8c87a,#f0d88a);color:#1a1a2e;font-weight:700;box-shadow:0 4px 20px rgba(232,200,122,.3)}
.ctrl-lg.playing{background:linear-gradient(135deg,#d4a853,#e8c87a)}
.settings{display:flex;justify-content:center;align-items:center;gap:16px;flex-wrap:wrap}
.set-btn{padding:5px 14px;border-radius:16px;font-size:12px;cursor:pointer}
.set-btn.on{border:1px solid #e8c87a;background:rgba(232,200,122,.15);color:#e8c87a}
.set-btn.off{border:1px solid rgba(255,255,255,.15);background:transparent;color:#888}
.interval{display:flex;align-items:center;gap:6px;font-size:12px;color:#888}
.interval input{width:70px;accent-color:#e8c87a}
.interval .val{color:#e8c87a;min-width:24px;text-align:center}
.add-btn{width:100%;padding:13px;border-radius:14px;border:1px dashed rgba(232,200,122,.4);background:rgba(232,200,122,.08);color:#e8c87a;font-size:13px;cursor:pointer;margin-bottom:14px}
.add-form{background:rgba(255,255,255,.06);border-radius:14px;padding:14px;margin-bottom:14px;border:1px solid rgba(232,200,122,.15)}
.add-form input{width:100%;padding:9px 11px;border-radius:8px;border:1px solid rgba(255,255,255,.15);background:rgba(0,0,0,.3);color:#fff;font-size:14px;margin-bottom:7px;outline:none}
.add-form input::placeholder{color:#555}
.form-btns{display:flex;gap:7px}
.btn-gold{flex:1;padding:9px;border-radius:8px;border:none;background:#e8c87a;color:#1a1a2e;font-size:13px;font-weight:600;cursor:pointer}
.btn-ghost{padding:9px 14px;border-radius:8px;border:1px solid rgba(255,255,255,.15);background:transparent;color:#888;font-size:13px;cursor:pointer}
.word-item{background:rgba(255,255,255,.04);border-radius:12px;padding:12px 14px;margin-bottom:7px;display:flex;align-items:center;justify-content:space-between;border:1px solid transparent}
.word-item.active{background:rgba(232,200,122,.1);border-color:rgba(232,200,122,.25)}
.word-info{flex:1;cursor:pointer}
.word-info .fr{font-size:16px;color:#fff;font-style:italic}
.word-info .zh{font-size:12px;color:#7a7a9a;margin-left:8px}
.word-info .ex{font-size:11px;color:#555;margin-top:3px;font-style:italic}
.word-actions{display:flex;gap:4px;margin-left:8px;flex-shrink:0}
.icon-btn{width:28px;height:28px;border-radius:7px;border:1px solid rgba(255,255,255,.1);background:transparent;color:#888;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.icon-btn.del{color:#664444}
.edit-inputs input{width:100%;padding:5px 7px;border-radius:6px;border:1px solid rgba(255,255,255,.2);background:rgba(0,0,0,.3);color:#fff;font-size:13px;margin-bottom:4px;outline:none}
.edit-btns{display:flex;gap:5px;margin-top:2px}
.edit-btns button{padding:3px 10px;border-radius:6px;font-size:11px;cursor:pointer}
.empty{text-align:center;color:#555;padding:36px 0;font-size:13px}
</style>
</head>
<body>
<div class="app" id="app"></div>
<script>
const STORAGE_KEY="fr-vocab";
const DEFAULT_WORDS=[
  {id:1,fr:"tasse",zh:"茶杯（有把手，装热饮）",ex:"Une tasse de café"},
  {id:2,fr:"verre",zh:"玻璃杯（没把手，装冷饮）",ex:"Un verre d'eau"},
  {id:3,fr:"peut-être",zh:"也许",ex:"Peut-être demain"},
  {id:4,fr:"mince",zh:"糟糕（感叹词）",ex:"Mince, j'ai oublié !"},
  {id:5,fr:"s'il te plaît",zh:"请（对亲近的人）",ex:"Un café, s'il te plaît"},
  {id:6,fr:"s'il vous plaît",zh:"请（对陌生人/正式）",ex:"L'addition, s'il vous plaît"},
  {id:7,fr:"trop",zh:"太（过度）",ex:"C'est trop cher"},
  {id:8,fr:"très",zh:"很（程度高）",ex:"C'est très bon"},
  {id:9,fr:"déjeuner",zh:"午餐",ex:"Le déjeuner est prêt"},
  {id:10,fr:"repas",zh:"一顿饭（泛指）",ex:"Un bon repas"},
  {id:11,fr:"bonjour",zh:"你好",ex:"Bonjour, comment allez-vous ?"}
];

let words=[], currentIndex=0, isPlaying=false, loop=true, gap=3, showMeaning=true, view="player", showAdd=false, editingId=null, timer=null;

function loadWords(){
  try{
    const s=localStorage.getItem(STORAGE_KEY);
    if(s){const p=JSON.parse(s);if(Array.isArray(p)&&p.length)return p}
  }catch(e){}
  return JSON.parse(JSON.stringify(DEFAULT_WORDS));
}
function saveWords(){try{localStorage.setItem(STORAGE_KEY,JSON.stringify(words))}catch(e){}}

function speak(text){
  return new Promise(resolve=>{
    speechSynthesis.cancel();
    const u=new SpeechSynthesisUtterance(text);
    u.lang="fr-FR";u.rate=0.85;
    const v=speechSynthesis.getVoices().find(v=>v.lang.startsWith("fr"));
    if(v)u.voice=v;
    u.onend=resolve;u.onerror=resolve;
    speechSynthesis.speak(u);
  });
}

function stopPlay(){isPlaying=false;clearTimeout(timer);speechSynthesis.cancel()}

function startPlay(){
  isPlaying=true;render();
  function go(){
    if(!isPlaying||!words.length)return;
    speak(words[currentIndex].fr).then(()=>{
      if(!isPlaying)return;
      timer=setTimeout(()=>{
        if(!isPlaying)return;
        currentIndex++;
        if(currentIndex>=words.length){
          if(loop){currentIndex=0}else{stopPlay();render();return}
        }
        render();go();
      },gap*1000);
    });
  }
  go();
}

function render(){
  const app=document.getElementById("app");
  const cur=words[currentIndex]||null;
  let h=`<div class="header"><div><div class="logo">Mon Vocabulaire</div><div class="sub">${words.length} mots · 阿衡的法语磨耳朵</div></div><div class="tabs"><button class="tab ${view==="player"?"on":"off"}" onclick="view='player';render()">播放</button><button class="tab ${view==="list"?"on":"off"}" onclick="view='list';render()">词库</button></div></div><div class="content">`;

  if(view==="player"&&cur){
    h+=`<div class="card"><div class="counter">${currentIndex+1} / ${words.length}</div><div class="word-fr">${esc(cur.fr)}</div>`;
    if(showMeaning){
      h+=`<div class="word-zh">${esc(cur.zh)}</div>`;
      if(cur.ex)h+=`<div class="word-ex">"${esc(cur.ex)}"</div>`;
    }
    h+=`<button class="toggle-btn" onclick="showMeaning=!showMeaning;render()">${showMeaning?"隐藏释义":"显示释义"}</button></div>`;
    h+=`<div class="progress"><div class="progress-bar" style="width:${((currentIndex+1)/words.length)*100}%"></div></div>`;
    h+=`<div class="controls"><button class="ctrl-btn ctrl-sm" onclick="goPrev()">◁</button><button class="ctrl-btn ctrl-lg ${isPlaying?"playing":""}" onclick="togglePlay()">${isPlaying?"⏸":"▶"}</button><button class="ctrl-btn ctrl-sm" onclick="goNext()">▷</button></div>`;
    h+=`<div class="settings"><button class="set-btn ${loop?"on":"off"}" onclick="loop=!loop;render()">🔁 循环 ${loop?"开":"关"}</button><div class="interval"><span>间隔</span><input type="range" min="1" max="8" step="0.5" value="${gap}" oninput="gap=Number(this.value);render()"><span class="val">${gap}s</span></div><button class="set-btn off" onclick="speak('${esc(cur.fr)}')">🔊 再念一遍</button></div>`;
  }

  if(view==="list"){
    h+=`<button class="add-btn" onclick="showAdd=!showAdd;render()">+ 添加新单词</button>`;
    if(showAdd){
      h+=`<div class="add-form"><input id="nfr" placeholder="法语单词"><input id="nzh" placeholder="中文释义"><input id="nex" placeholder="例句（选填）"><div class="form-btns"><button class="btn-gold" onclick="addWord()">添加</button><button class="btn-ghost" onclick="showAdd=false;render()">取消</button></div></div>`;
    }
    if(words.length===0){
      h+=`<div class="empty">还没有单词，点上面添加吧</div>`;
    }else{
      words.forEach((w,i)=>{
        if(editingId===w.id){
          h+=`<div class="word-item"><div class="edit-inputs" style="flex:1"><input id="efr" value="${esc(w.fr)}"><input id="ezh" value="${esc(w.zh)}"><input id="eex" value="${esc(w.ex||"")}"><div class="edit-btns"><button class="btn-gold" onclick="saveEdit(${w.id})">保存</button><button class="btn-ghost" onclick="editingId=null;render()">取消</button></div></div></div>`;
        }else{
          h+=`<div class="word-item ${currentIndex===i?"active":""}"><div class="word-info" onclick="currentIndex=${i};speak('${esc(w.fr)}');render()"><div><span class="fr">${esc(w.fr)}</span><span class="zh">${esc(w.zh)}</span></div>`;
          if(w.ex)h+=`<div class="ex">${esc(w.ex)}</div>`;
          h+=`</div><div class="word-actions"><button class="icon-btn" onclick="startEdit(${w.id})">✎</button><button class="icon-btn del" onclick="delWord(${w.id})">✕</button></div></div>`;
        }
      });
    }
  }

  h+=`</div>`;
  app.innerHTML=h;
}

function esc(s){return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;")}
function togglePlay(){if(isPlaying){stopPlay();render()}else{startPlay()}}
function goPrev(){stopPlay();currentIndex=currentIndex>0?currentIndex-1:words.length-1;speak(words[currentIndex].fr);render()}
function goNext(){stopPlay();currentIndex=currentIndex<words.length-1?currentIndex+1:0;speak(words[currentIndex].fr);render()}
function addWord(){
  const fr=document.getElementById("nfr").value.trim(),zh=document.getElementById("nzh").value.trim(),ex=document.getElementById("nex").value.trim();
  if(!fr)return;
  const maxId=words.reduce((m,w)=>Math.max(m,w.id),0);
  words.push({id:maxId+1,fr,zh,ex});
  saveWords();showAdd=false;render();
}
function delWord(id){words=words.filter(w=>w.id!==id);if(currentIndex>=words.length)currentIndex=Math.max(0,words.length-1);saveWords();render()}
function startEdit(id){editingId=id;render()}
function saveEdit(id){
  const fr=document.getElementById("efr").value.trim(),zh=document.getElementById("ezh").value.trim(),ex=document.getElementById("eex").value.trim();
  words=words.map(w=>w.id===id?{...w,fr,zh,ex}:w);editingId=null;saveWords();render();
}

speechSynthesis.getVoices();
setTimeout(()=>speechSynthesis.getVoices(),100);
words=loadWords();
render();
</script>
</body>
</html>
